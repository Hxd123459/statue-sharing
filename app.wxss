/* app.wxss - 全局样式 */
@import '/utils/font.wxss';
/* 白天主题 */
.theme-light {
  --bg-primary: #f7f9fc;
  --bg-card: #ffffff;
  --bg-soft: #f2f5fb;
  --text-primary: #263043;
  --text-secondary: #7f8aa3;
  --accent-color: #88a4c7;
  --accent-strong: #6f90ba;
  --divider-color: #e8edf4;
  --overlay-mask: rgba(27, 39, 60, 0.24);
  --shadow-soft: 0 10rpx 30rpx rgba(105, 128, 161, 0.08);
  --shadow-card: 0 4rpx 16rpx rgba(105, 128, 161, 0.06);
  --gold-gradient-start: #FFD700;
  --gold-gradient-end: #FFA500;
  --silver-gradient-start: #C0C0C0;
  --silver-gradient-end: #A8A8A8;
  --bronze-gradient-start: #CD7F32;
  --bronze-gradient-end: #B8722C;
}

/* 黑夜主题 */
.theme-dark {
  --bg-primary: #171b23;
  --bg-card: #202733;
  --bg-soft: #252d3a;
  --text-primary: #eef3fc;
  --text-secondary: #99a8c2;
  --accent-color: #8ea8cc;
  --accent-strong: #b4c4dd;
  --divider-color: #313b49;
  --overlay-mask: rgba(7, 9, 12, 0.55);
  --shadow-soft: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
  --shadow-card: 0 4rpx 16rpx rgba(0, 0, 0, 0.16);
  --gold-gradient-start: #FFD700;
  --gold-gradient-end: #FFA500;
  --silver-gradient-start: #D1D1D6;
  --silver-gradient-end: #C0C0C0;
  --bronze-gradient-start: #E8A87C;
  --bronze-gradient-end: #CD7F32;
}

/* 全局重置 */
page {
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  transition: background-color 0.3s ease, color 0.3s ease;
}

/* 通用工具类 */
.container {
  width: 100%;
  height: 100vh;
  background-color: var(--bg-primary);
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
