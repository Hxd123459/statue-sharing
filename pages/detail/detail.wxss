/* pages/detail/detail.wxss */
.container {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-primary);
  transition: background-color 0.3s ease;
}

/* 弹幕层：从右向左滚动，不阻挡点击 */
.danmaku-layer {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 900;
  overflow: hidden;
}

.danmaku-item {
  position: absolute;
  left: 100%;
  white-space: nowrap;
  font-size: 28rpx;
  color: #fff;
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 24rpx;
  backdrop-filter: blur(6rpx);
  will-change: transform;
  animation-name: danmaku-scroll;
  animation-timing-function: linear;
  animation-fill-mode: forwards;
}

@keyframes danmaku-scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-2000rpx); }
}

.current-status-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.content-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.icon-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.big-icon-wrap {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent-color, #8b5cf6), #7c3aed);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(139, 92, 246, 0.35);
  margin-bottom: 48rpx;
}

.big-icon {
  font-size: 140rpx;
  line-height: 1;
}

.count-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.count-num {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.count-unit {
  font-size: 32rpx;
  color: var(--text-secondary, #666);
}

.count-animate {
  animation: countChange 0.5s ease-out;
}

@keyframes countChange {
  0% {
    transform: scale(1.3);
    color: var(--accent-color);
  }
  50% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
  }
}

.tabbar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 24rpx 24rpx calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 1000;
  background-color: var(--bg-primary);
}

.tabbar {
  width: 100%;
  max-width: 680rpx;
  height: 120rpx;
  background-color: var(--bg-card);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  overflow: hidden;
  padding: 0 16rpx;
}

.tabbar-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
}

.tabbar-btn:active {
  opacity: 0.8;
}

.tabbar-btn-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  color: var(--text-secondary);
}

.tabbar-btn-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.tabbar-btn.primary .tabbar-btn-text {
  color: var(--accent-color);
  font-weight: 600;
}

/* 碰一下碰撞动画遮罩 */
.collision-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1200;
}

.collision-scene {
  position: relative;
  width: 680rpx;
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collision-icon {
  position: absolute;
  width: 176rpx;
  height: 176rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, var(--accent-color, #8b5cf6), #7c3aed);
  box-shadow: 0 16rpx 48rpx rgba(139, 92, 246, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  top: 50%;
  transform: translateY(-50%);
  z-index: 1;
}

.collision-icon-left {
  left: 40rpx;
}

.collision-icon-right {
  right: 40rpx;
}

.collision-emoji {
  font-size: 80rpx;
}

/* 冲向中心 */
.collision-scene.go .collision-icon-left {
  animation: collision-hit-right 0.15s cubic-bezier(0.8, 0, 1, 1) forwards;
}

.collision-scene.go .collision-icon-right {
  animation: collision-hit-left 0.15s cubic-bezier(0.8, 0, 1, 1) forwards;
}

@keyframes collision-hit-right {
  from { transform: translateY(-50%) translateX(0); }
  /* 124rpx ≈ 让两侧图标在中心刚好贴边、不重叠 */
  to   { transform: translateY(-50%) translateX(124rpx); }
}

@keyframes collision-hit-left {
  from { transform: translateY(-50%) translateX(0); }
  to   { transform: translateY(-50%) translateX(-124rpx); }
}

/* 撞住停留位置（不复原） */
.collision-scene.hit .collision-icon-left {
  transform: translateY(-50%) translateX(124rpx);
}

.collision-scene.hit .collision-icon-right {
  transform: translateY(-50%) translateX(-124rpx);
}

/* 回弹：稍微拉开一点距离 */
.collision-scene.rebound .collision-icon-left {
  animation: collision-rebound-left 0.22s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.collision-scene.rebound .collision-icon-right {
  animation: collision-rebound-right 0.22s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

@keyframes collision-rebound-left {
  from { transform: translateY(-50%) translateX(124rpx); }
  to   { transform: translateY(-50%) translateX(104rpx); }
}

@keyframes collision-rebound-right {
  from { transform: translateY(-50%) translateX(-124rpx); }
  to   { transform: translateY(-50%) translateX(-104rpx); }
}

/* 回弹后保持在回弹位置 */
.collision-scene.done .collision-icon-left {
  transform: translateY(-50%) translateX(104rpx);
}

.collision-scene.done .collision-icon-right {
  transform: translateY(-50%) translateX(-104rpx);
}

/* 爆裂三角符号容器 */
.collision-burst {
  position: absolute;
  /* 稍微靠近顶部，让爆炸明显在两图标之上 */
  top: 10rpx;
  left: 50%;
  width: 240rpx;
  height: 190rpx;
  transform: translateX(-50%) scale(0);
  transform-origin: bottom center;
  opacity: 0;
}

@keyframes collision-pop {
  0%   { opacity: 0; transform: translateX(-50%) scale(0.05); }
  65%  { opacity: 1; transform: translateX(-50%) scale(1.1); }
  100% { opacity: 1; transform: translateX(-50%) scale(1); }
}

/* 回弹时爆裂消散 */
.collision-scene.rebound .collision-burst,
.collision-scene.done .collision-burst {
  animation: collision-pop-out 0.15s ease forwards;
}

@keyframes collision-pop-out {
  from { opacity: 1; transform: translateX(-50%) scale(1); }
  to   { opacity: 0; transform: translateX(-50%) scale(1.3); }
}
/* 弹幕弹框（与 duration-picker 风格一致） */
.danmaku-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 9999;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.danmaku-content {
  width: 100%;
  background-color: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx;
  padding-bottom: calc(48rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.danmaku-content .picker-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.danmaku-content .picker-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

/* 弹幕列表样式：和 duration-picker 保持一致 */
.danmaku-options {
  height: 480rpx;
  margin-bottom: 32rpx;
}

.danmaku-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
  background-color: var(--bg-primary);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.danmaku-option:active {
  transform: scale(0.98);
}

.danmaku-option.active {
  background: linear-gradient(135deg, var(--accent-color), #7c3aed);
  border-color: var(--accent-color);
}

.danmaku-option .option-label {
  font-size: 32rpx;
  color: var(--text-primary);
}

.danmaku-option.active .option-label {
  color: #fff;
  font-weight: 500;
}

.danmaku-option .option-check {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.danmaku-content .picker-actions {
  display: flex;
  gap: 24rpx;
}

.danmaku-content .picker-actions button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.danmaku-content .picker-actions button::after {
  border: none;
}

.danmaku-content .btn-cancel {
  background-color: var(--bg-primary);
  color: var(--text-primary);
}

.danmaku-content .btn-confirm {
  background: linear-gradient(135deg, var(--accent-color), #7c3aed);
  color: white;
  font-weight: 500;
}

.danmaku-content .btn-confirm:active {
  opacity: 0.8;
}
