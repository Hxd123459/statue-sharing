/* pages/index/index.wxss */
/* 顶部导航 */
.top-navigation{
    position: fixed;
    z-index: 999;
  }
  .container {
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--bg-primary);
    transition: background-color 0.3s ease;
  }
  
  
  /* 滚动区域 */
  .scroll-area {
    flex: 1;
    overflow-y: auto;
  }
  
  /* 前3名 Podium 样式 */
  .podium-container {
    padding: 40rpx 28rpx;
    margin: 8rpx 24rpx 36rpx;
    background-color: var(--bg-card);
    border-radius: 28rpx;
    box-shadow: var(--shadow-card);
  }
  
  .podium {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 48rpx;
    min-height: 400rpx;
  }
  
  .podium-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    flex: 1;
  }
  
  /* 第1名 */
  .podium-item.rank-1 {
    margin-bottom: 60rpx;
  }
  
  .podium-item .crown {
    font-size: 48rpx;
    margin-bottom: -12rpx;
    animation: float 2s ease-in-out infinite;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10rpx); }
  }
  
  /* 排名徽章 */
  /* 头像容器 - 添加相对定位 */
  .avatar-container {
    margin: 24rpx 0;
    transition: transform 0.2s ease;
    position: relative;  /* 添加这行 */
  }
  
  .avatar-container:active {
    transform: scale(0.95);
  }
  
  /* 排名徽章 - 重新定位到底部 */
  .rank-badge {
    position: absolute;  /* 改为绝对定位 */
    bottom: -24rpx;      /* 负值让它向下移，一半在外面 */
    left: 50%;
    transform: translateX(-50%);
    width: 48rpx;
    height: 48rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    font-weight: bold;
    color: white;
    z-index: 3;  /* 确保在最上层 */
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  }
  
  .rank-badge.gold {
    background: linear-gradient(135deg, var(--gold-gradient-start), var(--gold-gradient-end));
  }
  
  .rank-badge.silver {
    background: linear-gradient(135deg, var(--silver-gradient-start), var(--silver-gradient-end));
  }
  
  .rank-badge.bronze {
    background: linear-gradient(135deg, var(--bronze-gradient-start), var(--bronze-gradient-end));
  }
  
  /* 头像容器 */
  .avatar-container {
    margin: 24rpx 0;
    transition: transform 0.2s ease;
  }
  
  .avatar-container:active {
    transform: scale(0.95);
  }
  
  .avatar-border {
    width: 140rpx;
    height: 140rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 4rpx solid;
    box-shadow: var(--shadow-card);
    background-color: var(--bg-card);
  }
  
  .avatar-container.champion .avatar-border {
    width: 160rpx;
    height: 160rpx;
    border-width: 6rpx;
  }
  
  .gold-gradient {
    border-color: var(--gold-gradient-start);
    background: linear-gradient(135deg, #f8e8a8 0%, #f0cc8a 100%);
  }
  
  .silver-gradient {
    border-color: var(--silver-gradient-start);
    background: linear-gradient(135deg, #dde3ee 0%, #c9d2e2 100%);
  }
  
  .bronze-gradient {
    border-color: var(--bronze-gradient-start);
    background: linear-gradient(135deg, #e8c8b0 0%, #d9b29a 100%);
  }
  
  .emoji {
    font-size: 64rpx;
  }
  
  .emoji.large {
    font-size: 72rpx;
  }
  
  /* 状态名称和人数 */
  .podium-item .status-name {
    font-size: 28rpx;
    color: var(--text-primary);
    margin-top: 12rpx;
    font-weight: 500;
  }
  
  .podium-item .status-count {
    font-size: 28rpx;
    color: var(--text-secondary);
    margin-top: 8rpx;
  }
  
  .podium-item .status-count.large {
    font-size: 32rpx;
    font-weight: bold;
    color: var(--accent-color);
  }
  
  /* 列表区域 */
  .status-list {
    padding: 0 24rpx 32rpx;
  }
  
  .status-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 128rpx;
    margin-bottom: 20rpx;
    padding: 0 36rpx;
    background-color: var(--bg-card);
    border-radius: 20rpx;
    box-shadow: var(--shadow-card);
    transition: all 0.2s ease;
  }
  
  .status-card:active {
    transform: scale(0.98);
  }
  
  
  .status-card.mine .card-left .rank-number,
  .status-card.mine .card-left .name,
  .status-card.mine .card-right .count {
    color: white !important;
  }
  
  .card-left {
    display: flex;
    align-items: center;
    gap: 16rpx;
  }
  
  .rank-number {
    width: 64rpx;
    height: 64rpx;
    border-radius: 50%;
    background-color: var(--bg-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
    font-weight: bold;
    color: var(--text-secondary);
  }
  
  .card-left .emoji {
    font-size: 64rpx;
  }
  
  .card-left .name {
    font-size: 32rpx;
    color: var(--text-primary);
    font-weight: 500;
  }
  
  .card-right {
    display: flex;
    align-items: center;
    gap: 12rpx;
  }
  
  .card-right .count {
    font-size: 32rpx;
    color: var(--accent-strong);
  }
  
  /* 底部安全距离 */
  .bottom-safe-area {
    height: 200rpx;
  }
  
  /* 加载状态 */
  .loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--overlay-mask);
    z-index: 9999;
  }
  
  .loading-spinner {
    width: 80rpx;
    height: 80rpx;
    border: 6rpx solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  
  .loading-text {
    margin-top: 24rpx;
    font-size: 28rpx;
    color: white;
  }
  .current-status-title{
    font-size: 28rpx;
    color: var(--text-primary);
  }
  
  /* ============ 排名更新动画 ============ */
  
  /* 前三名容器更新动画 */
  .podium-container.podium-update {
    animation: podiumPulse 0.6s ease-out;
  }
  
  @keyframes podiumPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.02); }
    100% { transform: scale(1); }
  }
  
  /* 排名上升动画 */
  .rank-up {
    animation: rankUpAnimation 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  @keyframes rankUpAnimation {
    0% {
      transform: translateY(30rpx) scale(0.9);
      opacity: 0;
    }
    50% {
      transform: translateY(-10rpx) scale(1.05);
    }
    100% {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }
  
  /* 排名下降动画 */
  .rank-down {
    animation: rankDownAnimation 0.6s ease-out;
  }
  
  @keyframes rankDownAnimation {
    0% {
      transform: translateY(-20rpx) scale(1.05);
      opacity: 1;
    }
    100% {
      transform: translateY(0) scale(0.95);
      opacity: 0.7;
    }
  }
  
  /* 数字滚动动画 */
  .count-animate {
    animation: countChange 0.5s ease-out;
  }
  
  @keyframes countChange {
    0% {
      transform: scale(1.3);
      color: var(--accent-color);
    }
    50% {
      transform: scale(1.1);
    }
    100% {
      transform: scale(1);
    }
  }
  
  /* 排名变化箭头 */
  .rank-arrow {
    position: absolute;
    top: -8rpx;
    right: -8rpx;
    font-size: 24rpx;
    color: #10b981;
    animation: arrowBounce 0.6s ease-in-out infinite;
  }
  
  .rank-arrow.down {
    color: #ef4444;
    animation: arrowBounceDown 0.6s ease-in-out infinite;
  }
  
  @keyframes arrowBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4rpx); }
  }
  
  @keyframes arrowBounceDown {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4rpx); }
  }
  
  /* 皇冠闪烁动画（第一名上升时） */
  .rank-up .crown {
    animation: crownShine 1s ease-in-out;
  }
  
  @keyframes crownShine {
    0%, 100% {
      transform: scale(1);
      filter: brightness(1);
    }
    50% {
      transform: scale(1.2);
      filter: brightness(1.5);
    }
  }
  
  /* 排名数字容器添加相对定位 */
  .rank-number {
    position: relative;  /* 添加这行，让箭头可以绝对定位 */
    width: 64rpx;
    height: 64rpx;
    border-radius: 50%;
    background-color: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
    font-weight: bold;
    color: var(--text-secondary);
  }