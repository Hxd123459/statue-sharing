/* components/tabbar/tabbar.wxss */

.tabbar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 1000;
  pointer-events: none;
  background-color: transparent;
  
}

.tabbar {
  position: relative;
  width: 680rpx;
  height: 112rpx;
  background-color: var(--bg-card);
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-soft);
  pointer-events: auto;
  overflow: hidden;
  padding-left: 10rpx;
  padding-right: 10rpx;
}

/* 背景滑块 */
.slider {
  position: absolute;
  /* left: 10rpx;
  right: 10rpx; */
  transform: translateY(-50%);
  width: 324rpx;
  height: 92rpx;
  background: var(--bg-soft);
  border-radius: 46rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1;
}

/* Tab项 */
.tab-item {
  position: relative;
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  z-index: 2;
  transition: transform 0.2s ease;
}

.tab-item:active {
  transform: scale(0.98);
}

.tab-item .icon {
  font-size: 40rpx;
  transition: transform 0.2s ease;
}

.tab-item .label {
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: color 0.3s ease, transform 0.2s ease;
}

/* 选中状态 */
.tab-item.active .icon {
  transform: scale(1.05);
}

.tab-item.active .label {
  color: var(--accent-strong);
  font-weight: 600;
}
